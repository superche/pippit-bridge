{
  "name": "pippit-bridge",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Pippit API gateway and adapter monorepo",
  "author": "superche",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/superche/pippit-bridge.git"
  },
  "homepage": "https://github.com/superche/pippit-bridge#readme",
  "bugs": {
    "url": "https://github.com/superche/pippit-bridge/issues"
  },
  "type": "module",
  "packageManager": "npm@12.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "^22.22.2 || ^24.15.0 || >=26.0.0"
  },
  "scripts": {
    "build:libs": "npm run build -w @pippit-bridge/core && npm run build -w @pippit-bridge/sdk && npm run build -w @pippit-bridge/mcp-server",
    "predev": "npm run build:libs",
    "dev": "node --env-file=.env --watch --import tsx apps/openrouter-facade/src/server.ts",
    "predev:chatgpt-app": "npm run build:libs",
    "dev:chatgpt-app": "node --env-file=.env --watch --import tsx apps/chatgpt-app/src/server.ts",
    "dev:mcp": "node --env-file=.env packages/mcp-server-pippit/src/stdio.ts",
    "build": "npm run build:libs && npm run build -w @pippit-bridge/openrouter-facade && npm run build -w @pippit-bridge/opencode-provider && npm run build -w @pippit-bridge/chatgpt-app",
    "start": "node apps/openrouter-facade/dist/server.js",
    "start:chatgpt-app": "node apps/chatgpt-app/dist/server.js",
    "pretypecheck": "npm run build:libs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "oxlint .",
    "pretest": "npm run build:libs",
    "test": "vitest run --configLoader native",
    "pretest:watch": "npm run build:libs",
    "test:watch": "vitest --configLoader native",
    "check": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "esbuild": "^0.28.1",
    "oxlint": "^1.32.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
