{
  "name": "pippit-bridge",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "OpenRouter-compatible BYOK video bridge for Pippit (Xiaoyunque)",
  "author": "superche",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/superche/pippit-bridge.git"
  },
  "homepage": "https://github.com/superche/pippit-bridge#readme",
  "bugs": {
    "url": "https://github.com/superche/pippit-bridge/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node --env-file=.env --watch --import tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "fastify": "^5.6.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "oxlint": "^1.32.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
