HOST=127.0.0.1
PORT=3000
# Required. Generate two different 32-byte values with: openssl rand -hex 32
BYOK_ENCRYPTION_KEY_HEX=
JOB_SIGNING_KEY_HEX=
# Required. SHA-256 of a high-entropy Management API Key used only by /api/v1/byok.
BYOK_MANAGEMENT_KEY_SHA256=
# Required. Comma-separated SHA-256 digests of Facade API Keys used by model/image/video routes.
FACADE_API_KEY_SHA256_ALLOWLIST=
# The encrypted single-instance file store. Use a persistent volume in containers.
BYOK_STORE_PATH=./data/byok-credentials.json
PIPPIT_BASE_URL=https://xyq.jianying.com
PIPPIT_REQUEST_TIMEOUT_MS=43200000
IMAGE_GENERATION_POLL_INTERVAL_MS=3000
IMAGE_GENERATION_TIMEOUT_MS=43200000
CONTENT_STREAM_IDLE_TIMEOUT_MS=43200000
REFERENCE_FETCH_TIMEOUT_MS=43200000
REFERENCE_MAX_IMAGE_BYTES=31457280
REFERENCE_MAX_VIDEO_BYTES=209715200
REFERENCE_MAX_AUDIO_BYTES=15728640
REFERENCE_MAX_TOTAL_BYTES=314572800
REFERENCE_MAX_REDIRECTS=3
REFERENCE_UPLOAD_CONCURRENCY=1
REFERENCE_GLOBAL_CONCURRENCY=1
ALLOW_PRIVATE_REFERENCE_URLS=false
# Optional. When set, polling_url and unsigned_urls are absolute.
PUBLIC_BASE_URL=

# MCP / ChatGPT App / Codex wrappers. These call the facade; raw Pippit AKs never enter tool arguments.
PIPPIT_FACADE_BASE_URL=http://127.0.0.1:3000
# Required by every wrapper. Raw Facade API Key, not its SHA-256 digest and not a Pippit AK.
PIPPIT_FACADE_API_KEY=
PIPPIT_FACADE_TIMEOUT_MS=43200000
# Optional for stdio MCP / Codex account management. This is the raw Management API Key
# whose digest is BYOK_MANAGEMENT_KEY_SHA256. It is never exposed to ChatGPT App tools.
PIPPIT_FACADE_MANAGEMENT_API_KEY=
# stdio MCP and Codex only. Relative paths resolve from the MCP process working directory.
PIPPIT_MCP_OUTPUT_ROOT=./pippit-video-outputs
# Optional loopback AK enrollment controls. Port 0 chooses an ephemeral port.
PIPPIT_MCP_ENROLLMENT_PORT=0
PIPPIT_MCP_ENROLLMENT_TTL_MS=300000

# ChatGPT App Streamable HTTP endpoint: http://127.0.0.1:8787/mcp by default.
CHATGPT_APP_HOST=127.0.0.1
CHATGPT_APP_PORT=8787
# Media previews are disabled when both values below are empty. Set both or neither.
# Use the public HTTPS tunnel/deployment origin without a trailing /mcp route.
CHATGPT_APP_PUBLIC_BASE_URL=
# Optional paired value above. Generate an independent key with: openssl rand -hex 32
CHATGPT_APP_MEDIA_SIGNING_KEY_HEX=
# Signed preview lifetime; accepted range is 30-900 seconds.
CHATGPT_APP_MEDIA_TTL_SECONDS=300
